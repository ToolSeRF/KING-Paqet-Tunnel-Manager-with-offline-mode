uninstall_all() {
  render_header; render_log_box
  echo "${c_bold}UNINSTALL ALL${c_reset}"
  echo
  echo "This will:"
  echo " - stop & disable ALL paqet-client-* and paqet-server-* services"
  echo " - delete their service files and yaml configs"
  echo " - delete /usr/local/bin/paqet"
  echo
  local confirm=""
  read_line "Type 'yes' to confirm: " confirm
  confirm="${confirm// /}"
  if [[ "$confirm" != "yes" ]]; then
    log_warn "Uninstall cancelled"
    pause_enter
    return 0
  fi

  local services=()
  mapfile -t services < <(list_paqet_services || true)

  local s
  for s in "${services[@]}"; do
    log_info "Uninstall: $s"
    systemctl disable --now "$s" >/dev/null 2>&1 || true
    rm -f "/etc/systemd/system/${s}.service" >/dev/null 2>&1 || true
    rm -f "/etc/paqet/${s}.yaml" >/dev/null 2>&1 || true
    render_header; render_log_box
  done

  rm -f /etc/paqet/paqet-client-*.yaml /etc/paqet/paqet-server-*.yaml >/dev/null 2>&1 || true

  systemctl daemon-reload >/dev/null 2>&1 || true

  if [[ -f /usr/local/bin/paqet ]]; then
    rm -f /usr/local/bin/paqet >/dev/null 2>&1 || true
    log_ok "Removed /usr/local/bin/paqet"
  else
    log_info "paqet binary not found at /usr/local/bin/paqet"
  fi

  log_ok "Uninstall all completed"
  pause_enter
}

