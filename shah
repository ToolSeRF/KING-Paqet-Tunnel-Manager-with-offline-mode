  fi

  log_info "Enabling & starting service: $service_name"
  if systemctl enable --now "$service_name" >/dev/null 2>&1; then
    log_ok "Service started: $service_name"
  else
    log_err "Failed to enable/start service: $service_name"
  fi

  echo
  hr "="
  echo "${c_bold}systemctl status ${service_name}${c_reset}"
  hr "-"
  systemctl status "$service_name" --no-pager || true
  hr "="
  echo
}

parse_forward_mappings() {
  local input="$1" server_ip="$2"
  local yaml=""
  local part
  for part in $input; do
    part="${part// /}"
    [[ -z "$part" ]] && continue
    if ! [[ "$part" =~ ^[0-9]+=[0-9]+$ ]]; then
      log_warn "Invalid mapping skipped: $part (expected local=target)"
      continue
    fi
    local l="${part%=*}"
    local t="${part#*=}"
    if ! normalize_port "$l" >/dev/null 2>&1 || ! normalize_port "$t" >/dev/null 2>&1; then
      log_warn "Invalid ports skipped: $part"
      continue
    fi
    yaml+="  - listen: \":${l}\"\n"
    yaml+="    target: \"${server_ip}:${t}\"\n"
    yaml+="    protocol: \"tcp\"\n"
  done
  [[ -z "$yaml" ]] && echo "" || printf "%b" "$yaml"
}

