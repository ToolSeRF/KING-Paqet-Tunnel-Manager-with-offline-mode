    echo "5) optimize"
    echo "6) uninstall"
    echo
    local ch=""
    if ! ask_choice_once "Select: " ch 1 2 3 4 5 6; then
      continue
    fi
    case "$ch" in
      1) menu_install_core_and_deps ;;
      2) menu_setup_server ;;
      3) menu_setup_client ;;
      4) menu_manage_services ;;
      5) optimizer_menu ;;
      6) uninstall_all ;;
    esac
  done
}


is_ipv4() {
  local ip="$1"
  [[ "$ip" =~ ^([0-9]{1,3}\.){3}[0-9]{1,3}$ ]] || return 1
  local IFS=.
  read -r a b c d <<<"$ip"
  for o in "$a" "$b" "$c" "$d"; do
    [[ "$o" =~ ^[0-9]+$ ]] || return 1
    (( o>=0 && o<=255 )) || return 1
  done
  return 0
}

cli_usage() {
  echo "Usage:"
  echo "  ./shah kharej <TID> <LISTEN_PORT> <CONN> <MODE> <MTU> <IFACE|auto> [--firewall] [--start] [--key KEY] [--kcp-...]"
  echo "  ./shah iran   <TID> \"<MAPS>\" <SERVER_IP> <SERVER_PORT> <CONN> <MODE> <MTU> <IFACE|auto> <KEY> [--start] [--kcp-...]"
  echo
  echo "MODE: fast | fast2 | fast3 | manual"
  echo
  echo "KCP manual flags (only needed when MODE=manual):"
  echo "  --kcp-nodelay N     (0/1)"
  echo "  --kcp-interval N    (ms)"
  echo "  --kcp-resend N      (0-2)"
  echo "  --kcp-nc N          (0/1)"
  echo "  --kcp-rcvwnd N"
  echo "  --kcp-sndwnd N"
  echo "  --kcp-smuxbuf N"
  echo "  --kcp-streambuf N"
  echo
  echo "Examples:"
  echo "  ./shah kharej 44 8443 4 fast   1300 auto --firewall --start"
  echo "  ./shah iran   44 \"8443=8443 80=8080\" 10.10.20.10 8443 4 fast 1300 auto YOUR_KEY --start"
  echo
  echo "Manual example:"
  echo "  ./shah kharej 45 9000 6 manual 1300 ens3 --key YOUR_KEY --kcp-interval 10 --kcp-resend 2 --kcp-rcvwnd 4096 --kcp-sndwnd 4096 --start"
  echo "  ./shah iran   45 \"9000=9000\" 10.10.20.10 9000 6 manual 1300 auto YOUR_KEY --kcp-interval 10 --kcp-resend 2 --kcp-rcvwnd 2048 --kcp-sndwnd 2048 --start"
}

is_uint() { [[ "${1:-}" =~ ^[0-9]+$ ]]; }

cli_set_kcp_defaults() {
  local role="$1" # server|client
  KCP_NODELAY="1"
  KCP_INTERVAL="10"
  KCP_RESEND="2"
  KCP_NC="1"
  KCP_SMUXBUF="4194304"
  KCP_STREAMBUF="2097152"
  if [[ "$role" == "server" ]]; then
    KCP_RCVWND="2048"
    KCP_SNDWND="2048"
  else
    KCP_RCVWND="1024"
    KCP_SNDWND="1024"
  fi
}

cli_apply_kcp_flag() {
  local role="$1" flag="$2" val="$3"
  case "$flag" in
    --kcp-nodelay)  is_uint "$val" && { [[ "$val" == "0" || "$val" == "1" ]]; } || return 1; KCP_NODELAY="$val" ;;
    --kcp-interval) is_uint "$val" || return 1; KCP_INTERVAL="$val" ;;
    --kcp-resend)   is_uint "$val" || return 1; KCP_RESEND="$val" ;;
    --kcp-nc)       is_uint "$val" && { [[ "$val" == "0" || "$val" == "1" ]]; } || return 1; KCP_NC="$val" ;;
    --kcp-rcvwnd)   is_uint "$val" || return 1; KCP_RCVWND="$val" ;;
    --kcp-sndwnd)   is_uint "$val" || return 1; KCP_SNDWND="$val" ;;
    --kcp-smuxbuf)  is_uint "$val" || return 1; KCP_SMUXBUF="$val" ;;
    --kcp-streambuf) is_uint "$val" || return 1; KCP_STREAMBUF="$val" ;;
    *) return 1 ;;
  esac
  return 0
}

cli_run_kharej() {
  local tid="${1:-}" listen_port="${2:-}" conn="${3:-}" mode="${4:-}" mtu="${5:-}" iface="${6:-}"
  shift 6 || true

  if [[ -z "$tid" || -z "$listen_port" || -z "$conn" || -z "$mode" || -z "$mtu" || -z "$iface" ]]; then
    cli_usage; exit 1
  fi

  if ! is_uint "$tid" || (( tid < 1 || tid > 999 )); then echo "Invalid TID"; exit 1; fi
  listen_port="$(normalize_port "$listen_port" || true)"; [[ -z "$listen_port" ]] && { echo "Invalid LISTEN_PORT"; exit 1; }
  if ! is_uint "$conn" || (( conn < 1 || conn > 256 )); then echo "Invalid CONN"; exit 1; fi
  case "$mode" in fast|fast2|fast3|manual) ;; *) echo "Invalid MODE"; exit 1 ;; esac
  if ! is_uint "$mtu" || (( mtu < 50 || mtu > 1500 )); then echo "Invalid MTU"; exit 1; fi

  local do_firewall="0" do_start="0" key_override=""
  cli_set_kcp_defaults "server"

  while (($#)); do
    case "$1" in
      --firewall) do_firewall="1"; shift ;;
      --start) do_start="1"; shift ;;
      --key) shift; key_override="${1:-}"; [[ -z "$key_override" ]] && { echo "Missing KEY after --key"; exit 1; }; shift ;;
      --kcp-*) 
        local f="$1"; shift
        local v="${1:-}"; [[ -z "$v" ]] && { echo "Missing value for $f"; exit 1; }
        if ! cli_apply_kcp_flag "server" "$f" "$v"; then echo "Invalid value for $f"; exit 1; fi
        shift
        ;;
      *) echo "Unknown flag: $1"; exit 1 ;;
    esac
  done

  if [[ "$iface" == "auto" ]]; then
    INTERFACE=""
  else
    INTERFACE="$iface"
  fi

  if [[ "$mode" != "manual" ]]; then
    kcp_apply_preset "$mode" "server"
  fi

  local KEY=""
  if [[ -n "$key_override" ]]; then
    KEY="$key_override"
  else
    if ensure_cmd openssl; then
      KEY="$(openssl rand -base64 32 | tr -d '
' | tr -d '=' | tr '/+' 'ab')"
    else
      KEY="$(head -c 48 /dev/urandom | base64 | tr -d '
' | tr -d '=' | tr '/+' 'ab')"
    fi
  fi

  render_header; render_log_box
  echo "${c_bold}${c_green}YOUR KEY (copy it)${c_reset}"
  hr "-"
  echo "${c_bold}${KEY}${c_reset}"
  hr "-"
  echo

  log_info "Collecting server network info..."
  server_network_info ""

  local cfg=""
  cfg="$(write_server_yaml "$tid" "$listen_port" "$conn" "$mode" "$mtu" "$KEY")"

  if ! validate_config_file "$cfg"; then
    log_err "Config validation failed."
    exit 1
  fi

  local svc=""
  svc="$(write_systemd_service_file "server" "$tid" "$cfg")"

  if [[ "$do_firewall" == "1" ]]; then
    firewall_setup "$listen_port"
  fi

  if [[ "$do_start" == "1" ]]; then
    enable_start_and_show_status "$svc"
  else
    log_info "Created service: $svc (not started). Run: systemctl enable --now $svc"
  fi
}

cli_run_iran() {
  local tid="${1:-}" maps="${2:-}" server_ip="${3:-}" server_port="${4:-}" conn="${5:-}" mode="${6:-}" mtu="${7:-}" iface="${8:-}" key="${9:-}"
  shift 9 || true

  if [[ -z "$tid" || -z "$maps" || -z "$server_ip" || -z "$server_port" || -z "$conn" || -z "$mode" || -z "$mtu" || -z "$iface" || -z "$key" ]]; then
    cli_usage; exit 1
  fi

  if ! is_uint "$tid" || (( tid < 1 || tid > 999 )); then echo "Invalid TID"; exit 1; fi
  if ! is_ipv4 "$server_ip"; then echo "Invalid SERVER_IP"; exit 1; fi
  server_port="$(normalize_port "$server_port" || true)"; [[ -z "$server_port" ]] && { echo "Invalid SERVER_PORT"; exit 1; }
  if ! is_uint "$conn" || (( conn < 1 || conn > 256 )); then echo "Invalid CONN"; exit 1; fi
  case "$mode" in fast|fast2|fast3|manual) ;; *) echo "Invalid MODE"; exit 1 ;; esac
  if ! is_uint "$mtu" || (( mtu < 50 || mtu > 1500 )); then echo "Invalid MTU"; exit 1; fi

  local do_start="0"
  cli_set_kcp_defaults "client"

  while (($#)); do
    case "$1" in
      --start) do_start="1"; shift ;;
      --kcp-*)
        local f="$1"; shift
        local v="${1:-}"; [[ -z "$v" ]] && { echo "Missing value for $f"; exit 1; }
        if ! cli_apply_kcp_flag "client" "$f" "$v"; then echo "Invalid value for $f"; exit 1; fi
        shift
        ;;
      *) echo "Unknown flag: $1"; exit 1 ;;
    esac
  done

  if [[ "$iface" == "auto" ]]; then
    INTERFACE=""
  else
    INTERFACE="$iface"
  fi

  local FORWARDS_YAML=""
  FORWARDS_YAML="$(parse_forward_mappings "$maps" "$server_ip")"
  if [[ -z "$FORWARDS_YAML" ]]; then
    echo "Invalid MAPS. Example: \"8443=8443 80=8080\""
    exit 1
  fi

  if [[ "$mode" != "manual" ]]; then
    kcp_apply_preset "$mode" "client"
  fi

  render_header; render_log_box
  log_info "Collecting client network info..."
  server_network_info ""

  local cfg=""
  cfg="$(write_client_yaml "$tid" "$server_ip" "$server_port" "$conn" "$mode" "$mtu" "$key" "$FORWARDS_YAML")"

  if ! validate_config_file "$cfg"; then
    log_err "Config validation failed."
    exit 1
  fi

  local svc=""
  svc="$(write_systemd_service_file "client" "$tid" "$cfg")"

  if [[ "$do_start" == "1" ]]; then
    enable_start_and_show_status "$svc"
  else
    log_info "Created service: $svc (not started). Run: systemctl enable --now $svc"
  fi
}

shah_cli_entry() {
  local cmd="${1:-}"
  [[ -n "$cmd" ]] || return 1
  case "$cmd" in
    kharej)
      shift
      if (($# < 6)); then cli_usage; return 0; fi
      cli_run_kharej "$@"; return $? ;;
    iran)
      shift
      if (($# < 9)); then cli_usage; return 0; fi
      cli_run_iran "$@"; return $? ;;
    help|--help|-h)
      cli_usage; return 0 ;;
    *)
      return 1 ;;
  esac
}
trap 'ec=$?; log_err "Unexpected error (exit code $ec) at line ${BASH_LINENO[0]}: ${BASH_COMMAND}"; render_header; render_log_box; echo; echo "An error occurred. Returning to main menu..."; sleep 1' ERR

require_root
detect_distro
detect_arch
log_info "Wizard started. Distro=${DISTRO} ${DISTRO_VER}, Arch=${ARCH_TAG}"
if shah_cli_entry "$@"; then exit $?; fi
main_menu
