write_systemd_service_file() {
  local role="$1" tunnel_id="$2" config_file="$3"
  local service_name="paqet-${role}-${tunnel_id}"
  local service_file="/etc/systemd/system/${service_name}.service"
  local paqet_bin="/usr/local/bin/paqet"
  local workdir="/etc/paqet"

  {
    echo "[Unit]"
    echo "Description=Paqet Tunnel (${role}-${tunnel_id})"
    echo "After=network.target"
    echo
    echo "[Service]"
    echo "Type=simple"
    echo "User=root"
    echo "WorkingDirectory=${workdir}"
    echo "ExecStart=${paqet_bin} run -c ${config_file}"
    echo "Restart=always"
    echo "RestartSec=10"
    echo "RuntimeMaxSec=3600"
    echo "StandardOutput=journal"
    echo "StandardError=journal"
    echo "SyslogIdentifier=${service_name}"
    echo
    echo "[Install]"
    echo "WantedBy=multi-user.target"
  } > "$service_file"

  chmod 644 "$service_file"
  systemctl daemon-reload >/dev/null 2>&1 || true
  log_ok "Service file created: $service_file"
