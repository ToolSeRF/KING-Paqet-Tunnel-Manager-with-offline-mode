#!/usr/bin/env bash
set -Eeuo pipefail


LOG_LINES=()
MAX_LOG_LINES=4000

BANNER_TITLE="KING"
APP_TITLE="make great again iran"
LOG_BOX_MIN_HEIGHT=12

c_reset="$(tput sgr0 2>/dev/null || true)"
c_bold="$(tput bold 2>/dev/null || true)"
c_dim="$(tput dim 2>/dev/null || true)"
c_red="$(tput setaf 1 2>/dev/null || true)"
c_green="$(tput setaf 2 2>/dev/null || true)"
c_yellow="$(tput setaf 3 2>/dev/null || true)"
c_blue="$(tput setaf 4 2>/dev/null || true)"
c_cyan="$(tput setaf 6 2>/dev/null || true)"

add_log() {
  local msg="$1"
  local ts
  ts="$(date '+%Y-%m-%d %H:%M:%S')"
  LOG_LINES+=("[$ts] $msg")
  if ((${#LOG_LINES[@]} > MAX_LOG_LINES)); then
    LOG_LINES=("${LOG_LINES[@]: -MAX_LOG_LINES}")
  fi
}

log_info(){ add_log "${c_cyan}INFO${c_reset}  $*"; }
log_ok(){ add_log "${c_green}OK${c_reset}    $*"; }
log_warn(){ add_log "${c_yellow}WARN${c_reset}  $*"; }
log_err(){ add_log "${c_red}ERR${c_reset}   $*"; }

term_cols(){ tput cols 2>/dev/null || echo 100; }
term_lines(){ tput lines 2>/dev/null || echo 40; }

hr() {
  local ch="${1:--}"
  local n; n="$(term_cols)"
  printf '%*s\n' "$n" '' | tr ' ' "$ch"
}

clear_screen() { tput clear 2>/dev/null || clear; }

render_header() {
  local cols; cols="$(term_cols)"
  clear_screen
  echo "${c_bold}${c_blue}$(printf "%*s" $(( (cols+${#BANNER_TITLE})/2 )) "$BANNER_TITLE")${c_reset}"
  echo "${c_dim}$(printf "%*s" $(( (cols+${#APP_TITLE})/2 )) "$APP_TITLE")${c_reset}"
  hr "="
}

render_log_box() {
  local total_lines; total_lines="$(term_lines)"
  local log_h="$LOG_BOX_MIN_HEIGHT"
  if (( total_lines < 28 )); then log_h=8; fi

  echo "${c_bold}Action Log${c_reset}"
  hr "-"
  local start=0
  local n="${#LOG_LINES[@]}"
  if (( n > log_h )); then start=$((n - log_h)); fi
  local cols; cols="$(term_cols)"

  local i="$start"
  while (( i < n )); do
    local line="${LOG_LINES[i]}"
    if ((${#line} > cols)); then line="${line:0:cols-3}..."; fi
    printf '%s\n' "$line"
    i=$((i+1))
  done

  local shown=$((n - start))
  local pad=0
  while (( pad < (log_h - shown) )); do
    echo
    pad=$((pad+1))
  done
  hr "="
}

pause_enter() {
  echo
  read -r -p "Press Enter to continue..." _
}

require_root() {
  if [[ "$(id -u)" -ne 0 ]]; then
    echo "This script must be run as root."
    exit 1
  fi
}

ensure_cmd() { command -v "$1" >/dev/null 2>&1; }

read_line() {
  local prompt="$1" __var="$2" def="${3:-}"
  local out=""
  if [[ -n "$def" ]]; then
    read -er -p "$prompt" -i "$def" out
  else
    read -er -p "$prompt" out
  fi
  printf -v "$__var" '%s' "$out"
}

ask_choice_once() {
  local prompt="$1" __var="$2"; shift 2
  local allowed=("$@")
  local v=""
  read_line "$prompt" v
  v="${v// /}"
  local ok="0"
  for a in "${allowed[@]}"; do
    if [[ "$v" == "$a" ]]; then ok="1"; break; fi
  done
  if [[ "$ok" == "1" ]]; then
    printf -v "$__var" '%s' "$v"
    return 0
  fi
  log_warn "Invalid choice. Allowed: ${allowed[*]}"
  return 1
}

read_int_range() {
  local prompt="$1" __var="$2" min="$3" max="$4" def="${5:-}"
  local v=""
  while true; do
    if [[ -n "$def" ]]; then read_line "$prompt" v "$def"; else read_line "$prompt" v; fi
    v="${v// /}"
    if [[ -z "$v" && -n "$def" ]]; then v="$def"; fi
    if [[ "$v" =~ ^[0-9]+$ ]] && (( v >= min && v <= max )); then
      printf -v "$__var" '%s' "$v"
      return 0
    fi
    log_warn "Invalid number. Allowed range: $min-$max"
    render_header; render_log_box
  done
}

normalize_port() {
  local p="$1"
  [[ -z "$p" ]] && return 1
  [[ "$p" =~ ^[0-9]+$ ]] || return 1
  (( p >= 1 && p <= 65535 )) || return 1
  echo "$p"
}

validate_ipv4() {
  local ip="$1"
  [[ -z "$ip" ]] && return 1
  if ! [[ "$ip" =~ ^([0-9]{1,3}\.){3}[0-9]{1,3}$ ]]; then
    return 1
  fi
  local IFS='.'
  local -a o
  read -r -a o <<< "$ip"
  [[ "${#o[@]}" -ne 4 ]] && return 1
  local x
  for x in "${o[@]}"; do
    [[ "$x" =~ ^[0-9]+$ ]] || return 1
    (( x >= 0 && x <= 255 )) || return 1
  done
  return 0
}

read_ipv4_loop() {
  local prompt="$1" __var="$2" def="${3:-}"
  local ip=""
  while true; do
    if [[ -n "$def" ]]; then
      read_line "$prompt" ip "$def"
    else
      read_line "$prompt" ip
    fi
    ip="${ip// /}"
    if validate_ipv4 "$ip"; then
      printf -v "$__var" '%s' "$ip"
      return 0
    fi
    log_warn "Invalid IPv4. Example: 1.2.3.4"
    render_header; render_log_box
  done
}

DISTRO="unknown"
DISTRO_VER="unknown"
ARCH_TAG="unknown"

detect_distro() {
  DISTRO="unknown"; DISTRO_VER="unknown"
  if [[ -f /etc/os-release ]]; then
    . /etc/os-release
    DISTRO="${ID:-unknown}"
    DISTRO_VER="${VERSION_ID:-unknown}"
  fi
}

detect_arch() {
  local m; m="$(uname -m)"
  case "$m" in
    x86_64|amd64) ARCH_TAG="amd64" ;;
    aarch64|arm64) ARCH_TAG="arm64" ;;
    *) ARCH_TAG="unknown" ;;
  esac
}

default_interface() { ip route 2>/dev/null | awk '/default/ {print $5; exit}'; }

default_local_ip_for_iface() {
  local iface="$1"
  ip -o -4 addr show dev "$iface" scope global 2>/dev/null | awk '{split($4,a,"/"); print a[1]; exit}'
}

download_file() {
  local url="$1" out="$2"
  log_info "Downloading: $url -> $out"
  if ensure_cmd curl; then
    if curl -fL --connect-timeout 10 --retry 2 -o "$out" "$url"; then
      log_ok "Downloaded $out"
      return 0
    fi
  fi
  if ensure_cmd wget; then
    if wget -q -O "$out" "$url"; then
      log_ok "Downloaded $out"
      return 0
    fi
  fi
  log_err "Download failed: $url"
  return 1
}

extract_targz_in_place() {
  local file="$1" dest="$2"
  mkdir -p "$dest"

  if [[ ! -f "$file" ]]; then
    log_err "Archive not found: $file"
    return 1
  fi

  if ensure_cmd gzip; then
    if ! gzip -t "$file" >/dev/null 2>&1; then
      log_err "Archive is corrupted/incomplete (gzip test failed): $file"
      return 1
    fi
  fi

  log_info "Extracting: $file -> $dest"
  local errf="/tmp/paqet_extract_err.$$"
  if tar -xzf "$file" -C "$dest" >/dev/null 2>"$errf"; then
    rm -f "$errf" 2>/dev/null || true
    log_ok "Extracted $file"
    return 0
  fi

  local errtxt=""
  errtxt="$(head -n 2 "$errf" 2>/dev/null | tr '\n' ' ' || true)"
  rm -f "$errf" 2>/dev/null || true

  if echo "$errtxt" | grep -qi "unexpected end of file"; then
    log_err "Extract failed: archive is incomplete (download interrupted). File: $file"
  else
    log_err "Extract failed: $file | $errtxt"
  fi
  return 1
}

DEPS_LIST=(libpcap-dev net-tools iptables arp-scan curl wget git iptables-persistent)

install_deps_offline_from_dir() {
  local dir="$1"
  local failed=()
  local okcount=0
  local failcount=0

  log_info "Offline deps install from: $dir"
  if [[ ! -d "$dir" ]]; then
    log_err "Deps dir not found: $dir"
    return 1
  fi

  find_deb_for_pkg() {
    local base="$1" pkg="$2"
    local f=""
    f="$(find "$base" -type f \( \
          -name "${pkg}_*.deb" -o \
          -name "${pkg}-*.deb" -o \
          -name "${pkg}*.deb" \
        \) 2>/dev/null | head -n 1 || true)"
    echo "$f"
  }

  for pkg in "${DEPS_LIST[@]}"; do
    local deb
    deb="$(find_deb_for_pkg "$dir" "$pkg")"

    if [[ -z "$deb" || ! -f "$deb" ]]; then
      log_warn "DEB not found for: $pkg (skipping)"
      failed+=("$pkg")
      failcount=$((failcount+1))
      render_header; render_log_box
      continue
    fi

    log_info "Installing $pkg from $deb"

    if dpkg -i "$deb" >/dev/null 2>&1; then
      log_ok "$pkg installed"
      okcount=$((okcount+1))
    else
      if ensure_cmd apt-get; then
        log_warn "$pkg dpkg failed, trying apt-get -f install"
        DEBIAN_FRONTEND=noninteractive apt-get -y -f install >/dev/null 2>&1 || true
        if dpkg -i "$deb" >/dev/null 2>&1; then
          log_ok "$pkg installed (after fix)"
          okcount=$((okcount+1))
        else
          log_err "$pkg install failed (skipping)"
          failed+=("$pkg")
          failcount=$((failcount+1))
        fi
      else
        log_err "$pkg install failed and apt-get not found (skipping)"
        failed+=("$pkg")
        failcount=$((failcount+1))
      fi
    fi

    render_header; render_log_box
  done

  if (( failcount == 0 )); then
    log_ok "All deps success (8/8)"
  else
    log_warn "${okcount} deps success, ${failcount} deps failed: ${failed[*]}"
  fi
  return 0
}

install_deps_online() {
  log_info "Installing deps online via apt-get: ${DEPS_LIST[*]}"
  if ! ensure_cmd apt-get; then
    log_err "apt-get not found"
    return 1
  fi
  DEBIAN_FRONTEND=noninteractive apt-get update -y >/dev/null 2>&1 || true
  if DEBIAN_FRONTEND=noninteractive apt-get install -y "${DEPS_LIST[@]}"; then
    log_ok "Online deps installed"
    return 0
  fi
  log_err "Online deps install failed"
  return 1
}

install_paqet_binary_offline() {
  detect_arch
  local arch="$ARCH_TAG"
  if [[ "$arch" != "amd64" && "$arch" != "arm64" ]]; then
    log_err "Unsupported arch: $(uname -m)"
    return 1
  fi

  local primary_tar="/root/p_${arch}.tar.gz"

  local fallback_url=""
  local fallback_tar=""
  if [[ "$arch" == "arm64" ]]; then
    fallback_url="https://h4.linklick.ir/e68eee4ccf1abb9e6d4c814d0e6e7009/p_arm64.tar.gz"
    fallback_tar="/root/p_arm64.tar.gz"
  else
    fallback_url="https://h4.linklick.ir/e68eee4ccf1abb9e6d4c814d0e6e7009/p_amd64.tar.gz"
    fallback_tar="/root/p_amd64.tar.gz"
  fi

  local chosen_tar=""
  if [[ -f "$primary_tar" ]]; then
    chosen_tar="$primary_tar"
    log_ok "Found binary archive: $chosen_tar"
  else
    log_warn "Binary archive not found: $primary_tar"
    log_info "Trying fallback link: $fallback_url"
    if download_file "$fallback_url" "$fallback_tar"; then
      chosen_tar="$fallback_tar"
    else
      log_err "Binary archive not found and fallback download failed."
      log_err "Upload a valid archive to /root/ as p_${arch}.tar.gz OR fix the fallback link."
      return 1
    fi
  fi

  if ensure_cmd gzip; then
    if ! gzip -t "$chosen_tar" >/dev/null 2>&1; then
      log_warn "Binary archive corrupted/incomplete: $chosen_tar"
      rm -f "$chosen_tar" 2>/dev/null || true
      log_info "Re-downloading from fallback: $fallback_url"
      if download_file "$fallback_url" "$fallback_tar"; then
        chosen_tar="$fallback_tar"
        if ! gzip -t "$chosen_tar" >/dev/null 2>&1; then
          log_err "Fallback archive still corrupted after re-download: $chosen_tar"
          log_err "Stop. Provide a valid p_${arch}.tar.gz in /root/."
          return 1
        fi
      else
        log_err "Fallback download failed. Stop."
        log_err "Provide a valid p_${arch}.tar.gz in /root/."
        return 1
      fi
    fi
  fi

  local exdir="/root/paqet_bin_extract_${arch}"
  rm -rf "$exdir" 2>/dev/null || true
  mkdir -p "$exdir"

  if ! extract_targz_in_place "$chosen_tar" "$exdir"; then
    log_err "Binary extract failed. Provide a valid archive."
    return 1
  fi

  local bin=""
  bin="$(find "$exdir" -maxdepth 4 -type f -name "p_${arch}" 2>/dev/null | head -n 1 || true)"
  if [[ -z "$bin" ]]; then
    bin="$(find "$exdir" -maxdepth 6 -type f -iname "paqet*" 2>/dev/null | head -n 1 || true)"
  fi
  if [[ -z "$bin" || ! -f "$bin" ]]; then
    log_err "Could not find binary inside archive."
    log_err "Expected: p_${arch} or paqet* inside $chosen_tar"
    return 1
  fi

  chmod +x "$bin" >/dev/null 2>&1 || true
  if cp -f "$bin" /usr/local/bin/paqet; then
    chmod +x /usr/local/bin/paqet >/dev/null 2>&1 || true
    log_ok "Installed /usr/local/bin/paqet (offline)"
    return 0
  fi
  log_err "Copy to /usr/local/bin/paqet failed"
  return 1
}
BUNDLE_FILE=""
BUNDLE_DIR=""

choose_offline_bundle() {
  local os_tag="$1" mode_tag="$2"
  BUNDLE_FILE="/root/${os_tag}_${mode_tag}.tar.gz"

  local url=""
  case "${os_tag}_${mode_tag}" in
    2404arm64_minimal) url="https://h4.linklick.ir/e68eee4ccf1abb9e6d4c814d0e6e7009/2404arm64_minimal.tar.gz" ;;
    2404arm64_full)    url="https://h4.linklick.ir/e68eee4ccf1abb9e6d4c814d0e6e7009/2404arm64_full.tar.gz" ;;
    2404amd64_minimal) url="https://h4.linklick.ir/e68eee4ccf1abb9e6d4c814d0e6e7009/2404amd64_minimal.tar.gz" ;;
    2404amd64_full)    url="https://h4.linklick.ir/e68eee4ccf1abb9e6d4c814d0e6e7009/2404amd64_full.tar.gz" ;;
    2204arm64_minimal) url="https://h4.linklick.ir/e68eee4ccf1abb9e6d4c814d0e6e7009/2204arm64_minimal.tar.gz" ;;
    2204arm64_full)    url="https://h4.linklick.ir/e68eee4ccf1abb9e6d4c814d0e6e7009/2204arm64_full.tar.gz" ;;
    2204amd64_minimal) url="https://h4.linklick.ir/e68eee4ccf1abb9e6d4c814d0e6e7009/2204amd64_minimal.tar.gz" ;;
    2204amd64_full)    url="https://h4.linklick.ir/e68eee4ccf1abb9e6d4c814d0e6e7009/2204amd64_full.tar.gz" ;;
    *)
      url="https://h4.linklick.ir/e68eee4ccf1abb9e6d4c814d0e6e7009/${os_tag}_${mode_tag}.tar.gz"
      ;;
  esac

  if [[ ! -f "$BUNDLE_FILE" ]]; then
    log_warn "Offline bundle not found: $BUNDLE_FILE"
    if ! download_file "$url" "$BUNDLE_FILE"; then
      return 1
    fi
  else
    log_ok "Found bundle: $BUNDLE_FILE"
  fi

  if ! extract_targz_in_place "$BUNDLE_FILE" "/root"; then
    return 1
  fi

  BUNDLE_DIR="/root/${os_tag}_${mode_tag}"
  if [[ ! -d "$BUNDLE_DIR" ]]; then
    local top=""
    top="$(tar -tzf "$BUNDLE_FILE" 2>/dev/null | head -n 1 | cut -d/ -f1 || true)"
    if [[ -n "$top" && -d "/root/$top" ]]; then
      BUNDLE_DIR="/root/$top"
    fi
  fi

  if [[ ! -d "$BUNDLE_DIR" ]]; then
    log_err "Extracted directory not found for bundle"
    return 1
  fi
  return 0
}
INTERFACE=""
LOCAL_IP=""
GATEWAY_IP=""
GATEWAY_MAC=""
declare -a INTERFACE_IPV4S=()

select_interface_and_ipv4() {
  local items=()
  while read -r iface ip; do
    [[ -z "$iface" || -z "$ip" ]] && continue
    items+=("$iface|$ip")
  done < <(ip -o -4 addr show scope global 2>/dev/null | awk '{split($4,a,"/"); print $2, a[1]}' | sort -u)

  if ((${#items[@]} == 0)); then return 1; fi
  if ((${#items[@]} == 1)); then
    INTERFACE="${items[0]%%|*}"
    LOCAL_IP="${items[0]##*|}"
    return 0
  fi

  echo
  echo "${c_bold}Multiple interfaces found. Select one:${c_reset}"
  local idx=1
  for it in "${items[@]}"; do
    echo "$idx) ${it%%|*} -> ${it##*|}"
    idx=$((idx+1))
  done
  echo
  local choice=""
  read_int_range "Select (1-${#items[@]}): " choice 1 "${#items[@]}" "1"
  local picked="${items[choice-1]}"
  INTERFACE="${picked%%|*}"
  LOCAL_IP="${picked##*|}"
  return 0
}

server_network_info() {
  local BIND_IP="${1:-}"

  if [[ -n "$INTERFACE" && "$INTERFACE" != "not found" ]]; then
    log_info "Using interface (pre-set): $INTERFACE"
  elif [[ -n "$BIND_IP" ]]; then
    INTERFACE="$(ip -o -4 addr show scope global 2>/dev/null | awk -v ip="$BIND_IP" '{ split($4,a,"/"); if (a[1]==ip) {print $2; exit} }')"
    if [[ -z "$INTERFACE" ]]; then
      log_err "Could not find interface for BIND_IP=$BIND_IP"
      exit 1
    fi
    LOCAL_IP="$BIND_IP"
  else
    if ! select_interface_and_ipv4; then
      INTERFACE="$(default_interface || true)"
      if [[ -z "$INTERFACE" ]]; then log_err "Could not determine default route interface"; exit 1; fi
      LOCAL_IP="$(default_local_ip_for_iface "$INTERFACE" || true)"
      if [[ -z "$LOCAL_IP" ]]; then log_err "Could not determine LOCAL_IP for $INTERFACE"; exit 1; fi
    fi
  fi

  GATEWAY_IP="$(ip route 2>/dev/null | awk '/default/ {print $3; exit}')"
  [[ -z "$GATEWAY_IP" ]] && { log_err "Could not determine gateway IP"; exit 1; }

  GATEWAY_MAC="$(arp -n "$GATEWAY_IP" 2>/dev/null | awk -v gw="$GATEWAY_IP" '$1==gw {print $3; exit}')"
  if [[ -z "$GATEWAY_MAC" || "$GATEWAY_MAC" == "<incomplete>" ]]; then
    ping -c 1 "$GATEWAY_IP" >/dev/null 2>&1 || true
    GATEWAY_MAC="$(arp -n "$GATEWAY_IP" 2>/dev/null | awk -v gw="$GATEWAY_IP" '$1==gw {print $3; exit}')"
  fi
  [[ -z "$GATEWAY_MAC" || "$GATEWAY_MAC" == "<incomplete>" ]] && { log_err "Could not determine gateway MAC"; exit 1; }

  mapfile -t INTERFACE_IPV4S < <(ip -o -4 addr show dev "$INTERFACE" scope global 2>/dev/null | awk '{split($4,a,"/"); print a[1]}')
  [[ -z "$LOCAL_IP" ]] && LOCAL_IP="${INTERFACE_IPV4S[0]:-}"
  [[ -z "$LOCAL_IP" ]] && { log_err "LOCAL_IP is empty"; exit 1; }

  log_ok "Network info: IFACE=$INTERFACE LOCAL_IP=$LOCAL_IP GW_IP=$GATEWAY_IP GW_MAC=$GATEWAY_MAC"
}

iptables_rule_add_once() {
  local table="$1"; shift
  local chain="$1"; shift
  if iptables -t "$table" -C "$chain" "$@" >/dev/null 2>&1; then
    log_info "iptables rule exists ($table/$chain): $*"
  else
    if iptables -t "$table" -A "$chain" "$@"; then
      log_ok "iptables rule added ($table/$chain): $*"
    else
      log_err "iptables add failed ($table/$chain): $*"
    fi
  fi
}

firewall_setup() {
  local port="$1"
  if [[ "$port" == "80" || "$port" == "443" ]]; then
    log_warn "Port $port is sensitive (80/443). This can be risky."
  fi
  iptables_rule_add_once raw PREROUTING -p tcp --dport "$port" -j NOTRACK
  iptables_rule_add_once raw OUTPUT -p tcp --sport "$port" -j NOTRACK
  iptables_rule_add_once mangle OUTPUT -p tcp --sport "$port" --tcp-flags RST RST -j DROP

  detect_distro
  if [[ "$DISTRO" == "debian" || "$DISTRO" == "ubuntu" ]]; then
    mkdir -p /etc/iptables
    if ! dpkg -s iptables-persistent >/dev/null 2>&1; then
      log_warn "iptables-persistent not installed. Installing..."
      if ensure_cmd apt-get; then
        DEBIAN_FRONTEND=noninteractive apt-get update -y >/dev/null 2>&1 || true
        DEBIAN_FRONTEND=noninteractive apt-get install -y iptables-persistent >/dev/null 2>&1 || true
      fi
    fi
    if iptables-save > /etc/iptables/rules.v4; then
      log_ok "Saved iptables rules to /etc/iptables/rules.v4"
    else
      log_err "Failed to save iptables rules"
    fi
  else
    log_warn "Non Debian/Ubuntu distro: persistence not configured."
  fi
}

KCP_NODELAY="1"
KCP_INTERVAL="10"
KCP_RESEND="2"
KCP_NC="1"
KCP_RCVWND="2048"
KCP_SNDWND="2048"
KCP_SMUXBUF="4194304"
KCP_STREAMBUF="2097152"

kcp_apply_preset() {
  local mode="$1" role="$2"
  KCP_NODELAY="1"
  KCP_NC="1"

  if [[ "$mode" == "fast" ]]; then
    KCP_INTERVAL="10"
    KCP_RESEND="2"
    KCP_SMUXBUF="4194304"
    KCP_STREAMBUF="2097152"
    if [[ "$role" == "server" ]]; then KCP_RCVWND="2048"; KCP_SNDWND="2048"; else KCP_RCVWND="1024"; KCP_SNDWND="1024"; fi
  elif [[ "$mode" == "fast2" ]]; then
    KCP_INTERVAL="8"
    KCP_RESEND="2"
    if [[ "$role" == "server" ]]; then
      KCP_RCVWND="4096"; KCP_SNDWND="4096"
      KCP_SMUXBUF="8388608"; KCP_STREAMBUF="4194304"
    else
      KCP_RCVWND="2048"; KCP_SNDWND="2048"
      KCP_SMUXBUF="6291456"; KCP_STREAMBUF="3145728"
    fi
  elif [[ "$mode" == "fast3" ]]; then
    KCP_INTERVAL="6"
    KCP_RESEND="1"
    if [[ "$role" == "server" ]]; then
      KCP_RCVWND="8192"; KCP_SNDWND="8192"
      KCP_SMUXBUF="16777216"; KCP_STREAMBUF="8388608"
    else
      KCP_RCVWND="4096"; KCP_SNDWND="4096"
      KCP_SMUXBUF="12582912"; KCP_STREAMBUF="6291456"
    fi
  fi
}

yaml_escape() {
  local s="$1"
  s="${s//\\/\\\\}"
  s="${s//\"/\\\"}"
  printf '%s' "$s"
}

validate_config_file() {
  local config_file="$1"
  if [[ ! -f "$config_file" ]]; then
    log_err "Config not found: $config_file"
    return 1
  fi
  if grep -q "^role:" "$config_file" && (grep -q "\"client\"" "$config_file" || grep -q "\"server\"" "$config_file"); then
    log_ok "Configuration file validated: $config_file"
    return 0
  fi
  log_err "Invalid configuration: role not properly set in $config_file"
  return 1
}

