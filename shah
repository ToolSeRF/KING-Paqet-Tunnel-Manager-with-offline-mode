  if ! ensure_cmd systemctl; then return 1; fi
  systemctl list-unit-files --type=service --no-legend 2>/dev/null \
    | awk '{print $1}' \
    | sed 's/\.service$//' \
    | grep -E '^paqet-(client|server)-[0-9]+$' \
    | sort -V
}

cfg_path_from_service() {
  local s="$1"
  echo "/etc/paqet/${s}.yaml"
}

extract_first_number_field() {
  local cfg="$1" key="$2" def="${3:-}"
  local out=""
  out="$(awk -v k="$key" '
    $1==k":" {
      gsub(/[^0-9]/,"",$0);
      if ($0!="") {print $0; exit}
    }' "$cfg" 2>/dev/null || true)"
  [[ -z "$out" ]] && out="$def"
  echo "$out"
}

extract_first_quoted_field() {
  local cfg="$1" key="$2" def="${3:-}"
  local out=""
  out="$(awk -F'"' -v k="$key" '
    $1 ~ "^[[:space:]]*"k":[[:space:]]*$" {next}
    $0 ~ "^[[:space:]]*"k":[[:space:]]*\"" {print $2; exit}
  ' "$cfg" 2>/dev/null || true)"
  [[ -z "$out" ]] && out="$def"
  echo "$out"
}

client_extract_server_ip_from_cfg() {
  local cfg="$1"
  awk -F'"' '/^[[:space:]]*addr:[[:space:]]*"/ {print $2}' "$cfg" 2>/dev/null \
    | awk -F':' '{print $1; exit}'
}

client_extract_server_port_from_cfg() {
  local cfg="$1"
  awk -F'"' '/^[[:space:]]*addr:[[:space:]]*"/ {print $2}' "$cfg" 2>/dev/null \
    | awk -F':' '{print $2; exit}'
}

client_read_forward_mappings() {
  local cfg="$1"
  awk '
    BEGIN{inF=0; listen=""; target=""; proto=""}
    /^[[:space:]]*forward:[[:space:]]*$/ {inF=1; next}
    inF && /^[[:space:]]*network:[[:space:]]*$/ {exit}
    inF {
      if ($0 ~ /^[[:space:]]*-[[:space:]]*listen:[[:space:]]*"/) {
        gsub(/.*listen:[[:space:]]*"/,""); gsub(/".*/,"");
        gsub(/^:/,"");
        listen=$0
      } else if ($0 ~ /^[[:space:]]*target:[[:space:]]*"/) {
        gsub(/.*target:[[:space:]]*"/,""); gsub(/".*/,"");
        target=$0
      } else if ($0 ~ /^[[:space:]]*protocol:[[:space:]]*"/) {
        gsub(/.*protocol:[[:space:]]*"/,""); gsub(/".*/,"");
        proto=$0
      }
      if (listen!="" && target!="" && proto!="") {
        print listen "=" target
        listen=""; target=""; proto=""
      }
    }
  ' "$cfg" 2>/dev/null
}

client_write_forward_block_into_cfg() {
  local cfg="$1"
  shift
  local mappings=("$@")
  local tmp="/tmp/paqet_cfg.$$"

  awk '
    BEGIN{inF=0}
    /^[[:space:]]*forward:[[:space:]]*$/ {
      print $0
      inF=1
      next
    }
    inF && /^[[:space:]]*network:[[:space:]]*$/ {exit}
    !inF {print}
  ' "$cfg" > "$tmp" 2>/dev/null || { rm -f "$tmp"; return 1; }

  {
    for m in "${mappings[@]}"; do
      local lp="${m%%=*}"
      local tgt="${m#*=}"
      echo "  - listen: \":${lp}\""
      echo "    target: \"${tgt}\""
      echo "    protocol: \"tcp\""
    done
    echo
    awk '
      BEGIN{inF=0; started=0}
      /^[[:space:]]*forward:[[:space:]]*$/ {inF=1; next}
      inF && /^[[:space:]]*network:[[:space:]]*$/ {started=1}
      started {print}
    ' "$cfg"
  } >> "$tmp" 2>/dev/null

  if [[ -s "$tmp" ]]; then
    cp -f "$tmp" "$cfg"
    rm -f "$tmp" >/dev/null 2>&1 || true
    chmod 600 "$cfg" >/dev/null 2>&1 || true
    log_ok "Forward mappings updated in: $cfg"
    return 0
  fi
  rm -f "$tmp" >/dev/null 2>&1 || true
  return 1
}

parse_one_mapping_input() {
  local in="$1"
  in="${in// /}"
  local lp="" tp=""
  if [[ "$in" =~ ^[0-9]+=[0-9]+$ ]]; then
    lp="${in%=*}"
    tp="${in#*=}"
  else
    lp="$in"
    tp=""
  fi
  lp="$(normalize_port "$lp" 2>/dev/null || true)"
  [[ -z "$lp" ]] && return 1
  if [[ -n "$tp" ]]; then
    tp="$(normalize_port "$tp" 2>/dev/null || true)"
    [[ -z "$tp" ]] && return 1
    printf '%s %s' "$lp" "$tp"
    return 0
  fi
  printf '%s' "$lp"
  return 0
}

client_manage_forward_mapping() {
  local service_name="$1"
  local cfg; cfg="$(cfg_path_from_service "$service_name")"
  if [[ ! -f "$cfg" ]]; then
    log_err "Config not found: $cfg"
    pause_enter
    return 0
  fi

  local maps=()
  mapfile -t maps < <(client_read_forward_mappings "$cfg" || true)

  while true; do
    render_header; render_log_box
    echo "${c_bold}Forward Port Mapping: ${service_name}${c_reset}"
    echo
    local idx=1
    for m in "${maps[@]}"; do
      local lp="${m%%=*}"
      local tgt="${m#*=}"
      local tp="${tgt##*:}"
      echo "${idx}) ${lp}=${tp}"
      idx=$((idx+1))
    done
    echo "${idx}) add new port"
    echo "$((idx+1))) back"
    echo

    local ch=""
    local allowed=()
    local i
    for ((i=1;i<=idx+1;i++)); do allowed+=("$i"); done

    if ! ask_choice_once "Select: " ch "${allowed[@]}"; then
      continue
    fi

    if [[ "$ch" == "$((idx+1))" ]]; then
      return 0
    fi

    if [[ "$ch" == "$idx" ]]; then
      local srv_ip; srv_ip="$(client_extract_server_ip_from_cfg "$cfg")"
      [[ -z "$srv_ip" ]] && srv_ip="127.0.0.1"

      local in lp tp
      read_line "New listen port (or listen=target): " in
      in="${in// /}"
      if ! lp_tp="$(parse_one_mapping_input "$in" 2>/dev/null || true)"; then
        log_warn "Invalid listen/format"
        pause_enter
        continue
      fi

      lp="${lp_tp%% *}"
      tp="${lp_tp#* }"
      if [[ "$lp_tp" != *" "* ]]; then
        read_line "New target port: " tp
        tp="$(normalize_port "$tp" || true)"
        if [[ -z "$tp" ]]; then
          log_warn "Invalid target port"
          pause_enter
          continue
        fi
      fi

      maps+=("${lp}=${srv_ip}:${tp}")
      client_write_forward_block_into_cfg "$cfg" "${maps[@]}" || log_err "Failed to write mappings"
      svc_restart "$service_name"
      pause_enter
      return 0
    fi

    local sel_index=$((ch-1))
    local selected="${maps[$sel_index]}"
    local lp_old="${selected%%=*}"
    local tgt_old="${selected#*=}"
    local tp_old="${tgt_old##*:}"
    local host_old="${tgt_old%:*}"

    while true; do
      render_header; render_log_box
      echo "${c_bold}Selected: ${lp_old}=${tp_old}${c_reset}"
      echo
      echo "1) remove"
      echo "2) change"
      echo "3) back"
      echo
      local op=""
      if ! ask_choice_once "Select: " op 1 2 3; then
        continue
      fi
      if [[ "$op" == "3" ]]; then
        break
      elif [[ "$op" == "1" ]]; then
        unset 'maps[sel_index]'
        local newmaps=()
        for m in "${maps[@]}"; do [[ -n "$m" ]] && newmaps+=("$m"); done
        maps=("${newmaps[@]}")
        client_write_forward_block_into_cfg "$cfg" "${maps[@]}" || log_err "Failed to write mappings"
        svc_restart "$service_name"
        pause_enter
        return 0
      elif [[ "$op" == "2" ]]; then
        local lp_new tp_new
        read_line "New listen port (default ${lp_old}): " lp_new "$lp_old"
        lp_new="$(normalize_port "$lp_new" || true)"
        if [[ -z "$lp_new" ]]; then
          log_warn "Invalid listen port"
          pause_enter
          continue
        fi

        read_line "New target port (default ${tp_old}): " tp_new "$tp_old"
        tp_new="$(normalize_port "$tp_new" || true)"
        if [[ -z "$tp_new" ]]; then
          log_warn "Invalid target port"
          pause_enter
          continue
        fi

        maps[$sel_index]="${lp_new}=${host_old}:${tp_new}"
        client_write_forward_block_into_cfg "$cfg" "${maps[@]}" || log_err "Failed to write mappings"
        svc_restart "$service_name"
        pause_enter
        return 0
      fi
    done
  done
}

client_rewrite_full_config_from_manage() {
  local service_name="$1"
  local cfg; cfg="$(cfg_path_from_service "$service_name")"
  if [[ ! -f "$cfg" ]]; then
    log_err "Config not found: $cfg"
    pause_enter
    return 0
  fi

  local def_server_ip def_server_port def_conn def_mode def_mtu def_key
  def_server_ip="$(client_extract_server_ip_from_cfg "$cfg")"
  def_server_port="$(client_extract_server_port_from_cfg "$cfg")"
  def_conn="$(extract_first_number_field "$cfg" "conn" "4")"
  def_mode="$(extract_first_quoted_field "$cfg" "mode" "fast")"
  def_mtu="$(extract_first_number_field "$cfg" "mtu" "1300")"
  def_key="$(extract_first_quoted_field "$cfg" "key" "")"

  [[ -z "$def_server_port" ]] && def_server_port="8484"
  [[ -z "$def_conn" ]] && def_conn="4"
  [[ -z "$def_mode" ]] && def_mode="fast"
  [[ -z "$def_mtu" ]] && def_mtu="1300"

  local tunnel_id="${service_name##*-}"

  render_header; render_log_box
  log_info "Rewrite client config for: $service_name"
  echo "${c_bold}Rewrite Client Config${c_reset}"
  echo

  local SERVER_IP SERVER_PORT CONN_COUNT MTU KEY
  local KCP_CHOICE KCP_MODE

  read_ipv4_loop "Kharej Server ip: " SERVER_IP "$def_server_ip"

  read_line "Tun(kharej listen on) PORT (default ${def_server_port}): " SERVER_PORT "$def_server_port"
  SERVER_PORT="$(normalize_port "$SERVER_PORT" || true)"
  [[ -z "$SERVER_PORT" ]] && SERVER_PORT="$def_server_port"

  local MAPS=""
  read_line "map your Port Forwarding (example 8443=443 8080=8880): " MAPS
  local FORWARDS_YAML=""
  while true; do
    FORWARDS_YAML="$(parse_forward_mappings "$MAPS" "$SERVER_IP")"
    if [[ -n "$FORWARDS_YAML" ]]; then break; fi
    log_warn "No valid mappings. Try again."
    render_header; render_log_box
    read_line "map your Port Forwarding (example 8443=443 8080=8880): " MAPS
  done

  read_line "connection count (default ${def_conn}): " CONN_COUNT "$def_conn"
  if ! [[ "$CONN_COUNT" =~ ^[0-9]+$ ]] || (( CONN_COUNT < 1 || CONN_COUNT > 10000 )); then
    CONN_COUNT="$def_conn"
  fi

  while true; do
    render_header; render_log_box
    echo "${c_bold}KCP mode${c_reset}"
    echo "1) fast"
    echo "2) fast2"
    echo "3) fast3"
    echo "4) manual"
    echo
    if ! ask_choice_once "Select: " KCP_CHOICE 1 2 3 4; then
      continue
    fi
    break
  done
  case "$KCP_CHOICE" in
    1) KCP_MODE="fast" ;;
    2) KCP_MODE="fast2" ;;
    3) KCP_MODE="fast3" ;;
    4) KCP_MODE="manual" ;;
  esac

  read_line "set mtu (default ${def_mtu}): " MTU "$def_mtu"
  if ! [[ "$MTU" =~ ^[0-9]+$ ]] || (( MTU < 50 || MTU > 1500 )); then
    MTU="$def_mtu"
  fi

  local iface_guess
  iface_guess="$(default_interface || true)"
  [[ -z "$iface_guess" ]] && iface_guess="not found"
  read_line "interface (your interface is ${iface_guess}): " INTERFACE "${iface_guess}"
  [[ "$INTERFACE" == "not found" ]] && INTERFACE=""

  read_line "input your key: " KEY "$def_key"
  while [[ -z "$KEY" ]]; do
    log_warn "Key cannot be empty"
    render_header; render_log_box
    read_line "input your key: " KEY "$def_key"
  done

  if [[ "$KCP_MODE" == "manual" ]]; then
    render_header; render_log_box
    log_info "Manual KCP parameters"
    read_line "KCP_NODELAY (default 1): " KCP_NODELAY "1"
    read_line "KCP_INTERVAL ms (default 10): " KCP_INTERVAL "10"
    read_line "KCP_RESEND (default 2): " KCP_RESEND "2"
    read_line "KCP_NC (default 1): " KCP_NC "1"
    read_line "KCP_RCVWND (default 1024): " KCP_RCVWND "1024"
    read_line "KCP_SNDWND (default 1024): " KCP_SNDWND "1024"
    read_line "KCP_SMUXBUF (default 4194304): " KCP_SMUXBUF "4194304"
    read_line "KCP_STREAMBUF (default 2097152): " KCP_STREAMBUF "2097152"
  else
    kcp_apply_preset "$KCP_MODE" "client"
    log_info "Applied KCP preset for client: $KCP_MODE"
  fi

  render_header; render_log_box
  log_info "Collecting client network info..."
  server_network_info ""

  local new_cfg=""
  new_cfg="$(write_client_yaml "$tunnel_id" "$SERVER_IP" "$SERVER_PORT" "$CONN_COUNT" "$KCP_MODE" "$MTU" "$KEY" "$FORWARDS_YAML")"

  if ! validate_config_file "$new_cfg"; then
    log_err "Config validation failed."
    pause_enter
    return 0
  fi

  write_systemd_service_file "client" "$tunnel_id" "$new_cfg" >/dev/null 2>&1 || true

  svc_restart "$service_name"
  pause_enter
  return 0
}

server_extract_listen_port_from_cfg() {
  local cfg="$1"
  awk -F'"' '/^[[:space:]]*addr:[[:space:]]*"/ {print $2}' "$cfg" 2>/dev/null \
    | awk -F':' 'NF>=2 {print $2; exit}'
}

